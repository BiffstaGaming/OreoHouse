# OreoHouse web client — Apache rewrite rules.
#
# Keep PHP routing simple: only .php files are entry points. Static
# assets (css, js, png) serve directly. Anything else falls back to
# index.php which handles the login redirect.

RewriteEngine On

# Don't rewrite real files or directories.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# PWA manifest needs application/manifest+json so browsers will
# parse it. Default httpd config tags .webmanifest as text/plain
# which works but logs a console warning under strict installability
# audits.
AddType application/manifest+json .webmanifest

# Cache static assets for an hour. Excludes sw.js so a redeploy
# can roll out a new service worker without 24-hour-stale caches
# pinning the old one.
<FilesMatch "\.(css|js|png|jpg|svg|woff2?|webmanifest)$">
    Header set Cache-Control "public, max-age=3600"
</FilesMatch>
<Files "sw.js">
    Header set Cache-Control "no-cache, max-age=0, must-revalidate"
</Files>

# Send a few safety headers. We intentionally do NOT set CSP — the
# inline <script> in chat.php that injects window.OREO is essential
# and adding nonces here would add complexity for very little gain on
# a LAN-only deployment.
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "no-referrer"

# No directory listings.
Options -Indexes
