{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OreoHouse",
  "version": "0.21.2",
  "identifier": "com.oreo.house",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OreoHouse",
        "width": 800,
        "height": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BiffstaGaming/OreoHouse/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlEMjVFOTNGQUUzOUYzNEQKUldSTjh6bXVQK2tsblNDQUlnU2dyZEJmemtCZkpBekQ1Nnp3M0FZMEtzZHJQNzQ1d0puczZ5SlAK"
    }
  }
}
